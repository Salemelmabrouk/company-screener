# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Groq API ────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Database (Docker defaults — change for prod) ─
DATABASE_URL=jdbc:postgresql://postgres:5432/companyscreener
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost,http://localhost:80,http://localhost:8081
BACKEND_PORT=8080
FRONTEND_PORT=8081
